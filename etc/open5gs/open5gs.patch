+#include "nausf-handler.h"
+#include "nudm-build.h"
+#include "sbi-path.h"
+#include "ogs-sbi.h"
+
+#define PORT 60000
+
+int    server_sock  = 0;
+int    auth_count   = 0;
+
+pthread_cond_t  auth_cond           = PTHREAD_COND_INITIALIZER;
+pthread_mutex_t auth_cond_mutex     = PTHREAD_MUTEX_INITIALIZER;
+pthread_cond_t  send_auth_cond      = PTHREAD_COND_INITIALIZER;
+pthread_mutex_t send_auth_cond_mutex = PTHREAD_MUTEX_INITIALIZER;
+
+/* Flag for amf-sm.c: 1 while the socket thread is actively waiting
+ * for an AUSF response and intends to drive the NAS Auth Request
+ * itself. If 0 when amf-sm.c receives the AUSF response, the socket
+ * already timed out / moved on, so amf-sm.c must dispatch normally
+ * instead of blocking on send_auth_cond. */
+volatile int socket_waiting_for_auth = 0;
+volatile struct amf_event_s *event_auth = NULL;
+
+/* ---------- key-availability helpers ----------------------------------- */
+
+static bool check_kamf(uint8_t *kamf)
+{
+    int i;
+    for (i = 0; i < OGS_SHA256_DIGEST_SIZE; i++)
+        if (kamf[i] != 0) return true;
+    return false;
+}
+
+static bool check_int(uint8_t *intarr)
+{
+    int i;
+    for (i = 0; i < OGS_SHA256_DIGEST_SIZE / 2; i++)
+        if (intarr[i] != 0) return true;
+    return false;
+}
+
+static bool check_enc(uint8_t *encarr)
+{
+    int i;
+    for (i = 0; i < OGS_SHA256_DIGEST_SIZE / 2; i++)
+        if (encarr[i] != 0) return true;
+    return false;
+}
+
+static bool check_int_and_enc(uint8_t *intarr, uint8_t *encarr)
+{
+    return check_int(intarr) && check_enc(encarr);
+}
+
+static bool check_kgnb(uint8_t *kgnb)
+{
+    int i;
+    for (i = 0; i < OGS_SHA256_DIGEST_SIZE; i++)
+        if (kgnb[i] != 0) return true;
+    return false;
+}
+
+/* ---------- main socket thread ----------------------------------------- */
+
+void *conn(void *arg)
+{
+    struct sockaddr_in serv_addr;
+    int opt = 1, addrlen = sizeof(serv_addr), valread, server_fd;
+    int smd_replayed = 0, conf_upd_replayed = 0;
+
+    if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) < 0) {
+        perror("socket failed");
+        exit(EXIT_FAILURE);
+    }
+    if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt))) {
+        perror("setsockopt");
+        exit(EXIT_FAILURE);
+    }
+
+    serv_addr.sin_family      = AF_INET;
+    serv_addr.sin_addr.s_addr = INADDR_ANY;
+    serv_addr.sin_port        = htons(PORT);
+    if (inet_pton(AF_INET, "127.0.0.1", &serv_addr.sin_addr) <= 0) {
+        printf("Invalid address / Address not supported\n");
+        return NULL;
+    }
+    if (bind(server_fd, (struct sockaddr *)&serv_addr, sizeof(serv_addr)) < 0) {
+        perror("bind failed");
+        exit(EXIT_FAILURE);
+    }
+    if (listen(server_fd, 3) < 0) {
+        perror("listen");
+        exit(EXIT_FAILURE);
+    }
+
+    printf("[amf-socket] waiting for testing client on 127.0.0.1:%d ...\n", PORT);
+    fflush(stdout);
+
+    if ((server_sock = accept(server_fd, (struct sockaddr *)&serv_addr,
+                              (socklen_t *)&addrlen)) < 0) {
+        perror("accept");
+        exit(EXIT_FAILURE);
+    }
+
+    printf("[amf-socket] testing client connected (fd=%d)\n", server_sock);
+    fflush(stdout);
+    ogs_info("[amf-socket] testing client connected");
+
+    /* Hello handshake */
+    char test_buffer[1024] = {0};
+    valread = read(server_sock, test_buffer, sizeof(test_buffer) - 1);
+    ogs_info("[amf-socket] handshake: %s", test_buffer);
+    send_message("ACK from core\n");
+
+    while (1) {
+        char buffer[1024] = {0};
+        valread = read(server_sock, buffer, sizeof(buffer) - 1);
+        if (valread <= 0) {
+            printf("[amf-socket] testing client disconnected\n");
+            fflush(stdout);
+            break;
+        }
+
+        amf_ue_t *amf_ue  = ogs_list_first(&amf_self()->amf_ue_list);
+        ran_ue_t *ran_ue  = amf_ue ? ran_ue_find_by_id(amf_ue->ran_ue_id) : NULL;
+
+        ogs_info("[amf-socket] received: %s", buffer);
+
+        /* ---- reset counter ---- */
+        if (strcmp(buffer, "RACH_Reset\n") == 0) {
+            ogs_warn("[amf-socket] RACH_Reset");
+            regis_count = 0;
+            send_message("DONE\n");
+            continue;
+        }
+
+        /* ---- guard: UE must not have reconnected ---- */
+        if (regis_count > 1) {
+            ogs_warn("[amf-socket] regis_count > 1, sending null_action");
+            send_message("null_action\n");
+            continue;
+        }
+
+        if (!amf_ue) {
+            ogs_error("[amf-socket] no amf_ue, sending null_action");
+            send_message("null_action\n");
+            continue;
+        }
+
+        /* ====== NAS identity request ====== */
+        if (strcmp(buffer, "id_request\n") == 0) {
+            ogs_info("[amf-socket] id_request_plain_text");
+            CLEAR_AMF_UE_TIMER(amf_ue->t3570);
+            nas_5gs_send_identity_request(amf_ue);
+        }
+
+        /* ====== Authentication request (plain text) ======
+         * Active hook (5GBaseChecker style): trigger the AUSF
+         * Authenticate POST, block on auth_cond until amf-sm.c sees
+         * the AUSF response, then synchronously process the auth
+         * vector (which sends NAS Authentication Request to the UE).
+         * Finally signal send_auth_cond so amf-sm.c can resume; the
+         * intercept block there skips its own dispatch so the UE
+         * doesn't get a duplicate Auth Request. */
+        else if (strcmp(buffer, "auth_request_plain_text\n") == 0) {
+            ogs_info("[amf-socket] auth_request_plain_text (active)");
+            printf("[amf-socket] >>> auth_request_plain_text: queueing AUSF POST\n");
+            fflush(stdout);
+            auth_count = 0;
+            event_auth = NULL;
+            socket_waiting_for_auth = 1;
+
+            int sbi_rv = amf_ue_sbi_discover_and_send(
+                    OGS_SBI_SERVICE_TYPE_NAUSF_AUTH, NULL,
+                    amf_nausf_auth_build_authenticate, amf_ue, 0, NULL);
+            if (sbi_rv != OGS_OK) {
+                printf("[amf-socket] !!! AUSF discover_and_send failed (%d)\n",
+                        sbi_rv);
+                fflush(stdout);
+                socket_waiting_for_auth = 0;
+                send_message("null_action\n");
+                continue;
+            }
+
+            /* Wait up to 15s for amf-sm.c to signal the AUSF response.
+             * The first AUSF call after AMF startup includes NRF
+             * discovery which can take 7+ seconds on a cold cache. */
+            struct timespec ts;
+            clock_gettime(CLOCK_REALTIME, &ts);
+            ts.tv_sec += 15;
+            pthread_mutex_lock(&auth_cond_mutex);
+            int wait_rv = 0;
+            while (event_auth == NULL && wait_rv == 0) {
+                wait_rv = pthread_cond_timedwait(&auth_cond,
+                        &auth_cond_mutex, &ts);
+            }
+            pthread_mutex_unlock(&auth_cond_mutex);
+
+            /* Mark ourselves as no longer waiting BEFORE checking the
+             * outcome — so if amf-sm.c arrives just after our timeout,
+             * it sees socket_waiting_for_auth == 0 and dispatches
+             * normally instead of deadlocking on send_auth_cond. */
+            socket_waiting_for_auth = 0;
+
+            if (wait_rv != 0 || event_auth == NULL) {
+                printf("[amf-socket] !!! AUSF response timed out (rv=%d). "
+                       "Possible cause: SBI call from non-event-loop thread "
+                       "did not fire, or AUSF/UDM unreachable.\n", wait_rv);
+                fflush(stdout);
+                /* If amf-sm.c is somehow already blocked, unblock it. */
+                pthread_mutex_lock(&send_auth_cond_mutex);
+                pthread_cond_signal(&send_auth_cond);
+                pthread_mutex_unlock(&send_auth_cond_mutex);
+                send_message("null_action\n");
+                continue;
+            }
+
+            printf("[amf-socket] <<< AUSF response received, processing\n");
+            fflush(stdout);
+
+            /* Process the auth vector and send Auth Request to UE. */
+            ogs_sbi_message_t *auth_msg =
+                (ogs_sbi_message_t *)event_auth->h.sbi.message;
+            int auth_rv = amf_nausf_auth_handle_authenticate(amf_ue, auth_msg);
+
+            /* Tell amf-sm.c to resume (it will skip its own dispatch).
+             * Signal regardless of auth_rv — amf-sm.c is blocked on
+             * send_auth_cond and would deadlock otherwise. */
+            pthread_mutex_lock(&send_auth_cond_mutex);
+            pthread_cond_signal(&send_auth_cond);
+            pthread_mutex_unlock(&send_auth_cond_mutex);
+
+            if (auth_rv != OGS_OK) {
+                /* The NAS Auth Request couldn't be sent (typically because
+                 * the NG context was already removed — e.g. after radio link
+                 * failure between gNB and UE, see nas-path.c:481). Push
+                 * null_action immediately so the testing client doesn't
+                 * have to wait the full read timeout for an auth_response
+                 * that will never arrive. */
+                printf("[amf-socket] !!! amf_nausf_auth_handle_authenticate "
+                       "failed (rv=%d) — sending null_action\n", auth_rv);
+                fflush(stdout);
+                send_message("null_action\n");
+                continue;
+            }
+
+            printf("[amf-socket] === Auth Request sent to UE, awaiting response\n");
+            fflush(stdout);
+        }
+
+        /* ====== Authentication reject ====== */
+        else if (strcmp(buffer, "auth_reject\n") == 0) {
+            ogs_info("[amf-socket] auth_reject");
+            int rv = nas_5gs_send_authentication_reject(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] auth_reject failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Security mode command (plain) ======
+         * Semi-passive: actively sends NAS Security Mode Command to the
+         * UE; gmm-handler.c emits "nas_sm_complete" to the socket when
+         * the UE replies. (Was previously a no-op that relied on the
+         * auto-NAS-SMC fire from gmm_state_security_mode ENTRY; that
+         * auto-fire is now suppressed in gmm-sm.c.) */
+        else if (strcmp(buffer, "nas_sm_cmd\n") == 0) {
+            ogs_info("[amf-socket] nas_sm_cmd");
+            if (!check_kamf(amf_ue->kamf)) {
+                ogs_info("[amf-socket] no kamf for nas_sm_cmd");
+                send_message("null_action\n");
+                continue;
+            }
+            int rv = nas_5gs_send_security_mode_command(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] nas_sm_cmd failed");
+                send_message("null_action\n");
+                continue;
+            }
+            smd_replayed = 1;
+        }
+
+        /* ====== Security mode command – int+enc protected ====== */
+        else if (strcmp(buffer, "nas_sm_cmd_protected\n") == 0) {
+            ogs_info("[amf-socket] nas_sm_cmd_protected");
+            if (!check_int_and_enc(amf_ue->knas_int, amf_ue->knas_enc)) {
+                ogs_info("[amf-socket] no int/enc keys for smd_protected");
+                send_message("null_action\n");
+                continue;
+            }
+            int rv = nas_5gs_send_security_mode_command_protected(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] smd_protected failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Security mode command replay ====== */
+        else if (strcmp(buffer, "nas_sm_cmd_replay\n") == 0) {
+            ogs_info("[amf-socket] nas_sm_cmd_replay");
+            if (!smd_replayed) {
+                ogs_info("[amf-socket] no prior smd to replay");
+                send_message("null_action\n");
+                continue;
+            }
+            if (!check_int(amf_ue->knas_int)) {
+                ogs_info("[amf-socket] no integrity key for smd_replay");
+                send_message("null_action\n");
+                continue;
+            }
+            int rv = nas_5gs_send_security_mode_command_replay(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] nas_sm_cmd_replay failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Security mode command – null security plain text ====== */
+        else if (strcmp(buffer, "nas_sm_cmd_ns_plain_text\n") == 0) {
+            ogs_info("[amf-socket] nas_sm_cmd_ns_plain_text");
+            int rv = nas_5gs_send_security_mode_command_plain_text(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] nas_sm_cmd_ns_plain_text failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Security mode command – null security, int protected ====== */
+        else if (strcmp(buffer, "nas_sm_cmd_ns\n") == 0) {
+            ogs_info("[amf-socket] nas_sm_cmd_ns");
+            if (!check_kamf(amf_ue->kamf)) {
+                ogs_info("[amf-socket] no kamf for smd_ns");
+                send_message("null_action\n");
+                continue;
+            }
+            int rv = nas_5gs_send_security_mode_command_null_security_int(amf_ue);
+            if (rv != OGS_OK) {
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Registration accept – protected ====== */
+        else if (strcmp(buffer, "registration_accept_protected\n") == 0) {
+            if (!check_kgnb(amf_ue->kgnb)) {
+                ogs_info("[amf-socket] no kgnb for protected reg_accept");
+                send_message("null_action\n");
+                continue;
+            }
+            amf_ue_sbi_discover_and_send(
+                    OGS_SBI_SERVICE_TYPE_NUDM_UECM, NULL,
+                    amf_nudm_uecm_build_registration, amf_ue, 0, NULL);
+            ogs_info("[amf-socket] registration_accept_protected");
+            int rv = nas_5gs_send_registration_accept_dlnas(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] registration_accept_protected failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Registration accept – plain text ====== */
+        else if (strcmp(buffer, "registration_accept_plain_text\n") == 0) {
+            amf_ue_sbi_discover_and_send(
+                    OGS_SBI_SERVICE_TYPE_NUDM_UECM, NULL,
+                    amf_nudm_uecm_build_registration, amf_ue, 0, NULL);
+            ogs_info("[amf-socket] registration_accept_plain_text");
+            int rv = nas_5gs_send_registration_accept_plain_text_dlnas(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] registration_accept_plain_text failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Registration accept – header-4 plain text ====== */
+        else if (strcmp(buffer, "registration_accept_h4_plain_text\n") == 0) {
+            amf_ue_sbi_discover_and_send(
+                    OGS_SBI_SERVICE_TYPE_NUDM_UECM, NULL,
+                    amf_nudm_uecm_build_registration, amf_ue, 0, NULL);
+            ogs_info("[amf-socket] registration_accept_h4_plain_text");
+            int rv = nas_5gs_send_registration_accept_h4_plain_text_dlnas(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] registration_accept_h4_plain_text failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Configuration update command – protected ====== */
+        else if (strcmp(buffer, "config_update_cmd_protected\n") == 0) {
+            ogs_info("[amf-socket] config_update_cmd_protected");
+            if (!check_int_and_enc(amf_ue->knas_int, amf_ue->knas_enc)) {
+                ogs_info("[amf-socket] no int/enc keys for config_update_protected");
+                send_message("null_action\n");
+                continue;
+            }
+            gmm_configuration_update_command_param_t param;
+            memset(&param, 0, sizeof(param));
+            param.nitz = 1;
+            int rv = nas_5gs_send_configuration_update_command(amf_ue, &param);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] config_update_cmd_protected failed");
+                send_message("null_action\n");
+                continue;
+            }
+            conf_upd_replayed = 1;
+        }
+
+        /* ====== Configuration update command – plain text ====== */
+        else if (strcmp(buffer, "config_update_cmd_plain_text\n") == 0) {
+            ogs_info("[amf-socket] config_update_cmd_plain_text");
+            gmm_configuration_update_command_param_t param;
+            memset(&param, 0, sizeof(param));
+            param.nitz = 1;
+            int rv = nas_5gs_send_configuration_update_command_plain_text(amf_ue, &param);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] config_update_cmd_plain_text failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Configuration update command replay ====== */
+        else if (strcmp(buffer, "config_update_cmd_replay\n") == 0) {
+            ogs_info("[amf-socket] config_update_cmd_replay");
+            if (!check_int_and_enc(amf_ue->knas_int, amf_ue->knas_enc)) {
+                ogs_info("[amf-socket] no int/enc keys for config_update_replay");
+                send_message("null_action\n");
+                continue;
+            }
+            if (!conf_upd_replayed) {
+                ogs_info("[amf-socket] no prior config_update to replay");
+                send_message("null_action\n");
+                continue;
+            }
+            gmm_configuration_update_command_param_t param;
+            memset(&param, 0, sizeof(param));
+            param.nitz = 1;
+            int rv = nas_5gs_send_configuration_update_command_replay(amf_ue, &param);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] config_update_cmd_replay failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Registration reject ====== */
+        else if (strcmp(buffer, "registration_reject\n") == 0) {
+            ogs_info("[amf-socket] registration_reject");
+            if (!ran_ue) {
+                send_message("null_action\n");
+                continue;
+            }
+            int rv = nas_5gs_send_registration_reject(ran_ue, amf_ue,
+                    OGS_5GMM_CAUSE_PLMN_NOT_ALLOWED);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] registration_reject failed");
+                send_message("null_action\n");
+                continue;
+            }
+            amf_sbi_send_release_all_sessions(
+                    ran_ue, amf_ue, AMF_RELEASE_SM_CONTEXT_NO_STATE, NULL);
+        }
+
+        /* ====== Deregistration request – protected ====== */
+        else if (strcmp(buffer, "deregistration_req_protected\n") == 0) {
+            ogs_info("[amf-socket] deregistration_req_protected");
+            if (!check_int_and_enc(amf_ue->knas_int, amf_ue->knas_enc)) {
+                ogs_info("[amf-socket] no int/enc keys for dereg_protected");
+                send_message("null_action\n");
+                continue;
+            }
+            int rv = nas_5gs_send_de_registration_request(
+                    amf_ue, OpenAPI_deregistration_reason_NULL, 0);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] deregistration_req_protected failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== Deregistration request – plain text ====== */
+        else if (strcmp(buffer, "deregistration_req_plain_text\n") == 0) {
+            ogs_info("[amf-socket] deregistration_req_plain_text");
+            int rv = nas_5gs_send_de_registration_request_plain_text(amf_ue);
+            if (rv != OGS_OK) {
+                ogs_info("[amf-socket] deregistration_req_plain_text failed");
+                send_message("null_action\n");
+                continue;
+            }
+        }
+
+        /* ====== end session ====== */
+        else if (strcmp(buffer, "end") == 0) {
+            printf("[amf-socket] received end\n");
+            break;
+        }
+    }
+
+    return NULL;
+}
+
+/* ---- thread launcher -------------------------------------------------- */
+
+void thr_connect(void)
+{
+    pthread_t thr;
+    int ret = pthread_create(&thr, NULL, conn, NULL);
+    if (ret != 0) {
+        ogs_error("[amf-socket] pthread_create failed");
+        printf("[amf-socket] create thread error\n");
+        return;
+    }
+    ogs_info("[amf-socket] socket thread created");
+}
diff --git a/src/amf/amf-socket.h b/src/amf/amf-socket.h
new file mode 100644
--- /dev/null
+++ b/src/amf/amf-socket.h
@@ -0,0 +1,29 @@
+#ifndef OPEN5GS_AMF_SOCKET_H
+#define OPEN5GS_AMF_SOCKET_H
+
+#include <pthread.h>
+#include <stdbool.h>
+#include <stdint.h>
+
+extern int server_sock;
+
+/* auth-interception synchronisation */
+extern int auth_count;
+extern pthread_cond_t  auth_cond;
+extern pthread_mutex_t auth_cond_mutex;
+extern pthread_cond_t  send_auth_cond;
+extern pthread_mutex_t send_auth_cond_mutex;
+
+/* captured SBI auth event (set in amf-sm.c before signalling) */
+struct amf_event_s;
+extern volatile struct amf_event_s *event_auth;
+
+/* socket thread sets this to 1 while actively waiting for AUSF response;
+ * amf-sm.c reads it to decide whether to block on send_auth_cond */
+extern volatile int socket_waiting_for_auth;
+
+void  send_message(const char *message);
+void *conn(void *arg);
+void  thr_connect(void);
+
+#endif /* OPEN5GS_AMF_SOCKET_H */
diff --git a/src/amf/nausf-handler.c b/src/amf/nausf-handler.c
--- a/src/amf/nausf-handler.c
+++ b/src/amf/nausf-handler.c
@@ -156,7 +156,12 @@
     ogs_expect(r == OGS_OK);
     ogs_assert(r != OGS_ERROR);
 
-    return OGS_OK;
+    /* Propagate the actual NAS-send result. Previously this always returned
+     * OGS_OK regardless of `r`, which silently masked failures (e.g. NG
+     * context already removed → OGS_NOTFOUND). Both callers — gmm-sm.c
+     * (auto-flow) and amf-socket.c (testing-client active hook) — already
+     * branch on `rv != OGS_OK`; that branch was just unreachable. */
+    return r;
 }
 
 int amf_nausf_auth_handle_authenticate_confirmation(
