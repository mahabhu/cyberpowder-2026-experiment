diff --git a/src/amf/amf-sm.c b/src/amf/amf-sm.c
--- a/src/amf/amf-sm.c
+++ b/src/amf/amf-sm.c
@@ -20,6 +20,7 @@
 #include "sbi-path.h"
 #include "ngap-path.h"
 #include "nas-path.h"
+#include "amf-socket.h"
 #include "ngap-handler.h"
 #include "nnrf-handler.h"
 #include "namf-handler.h"
@@ -521,7 +522,59 @@
             e->h.sbi.message = &sbi_message;;
             e->h.sbi.state = state;
 
-            ogs_fsm_dispatch(&amf_ue->sm, e);
+            /* Intercept AUSF auth response so the socket thread can
+             * process the auth vector synchronously before the FSM.
+             * On the first AUSF response (POST = authenticate), block
+             * the AMF event loop until the socket thread finishes
+             * sending NAS Auth Request to the UE, then skip dispatch
+             * to avoid a duplicate Auth Request. The second AUSF
+             * response (PUT = authenticate confirmation) flows through
+             * normally to drive the rest of the FSM. */
+            int auth_intercepted = 0;
+            if (strcmp(sbi_message.h.service.name,
+                       OGS_SBI_SERVICE_NAME_NAUSF_AUTH) == 0) {
+                printf("[amf-sm] AUSF response received (auth_count=%d, "
+                       "socket_waiting=%d), signalling socket\n",
+                       auth_count, socket_waiting_for_auth);
+                fflush(stdout);
+                pthread_mutex_lock(&auth_cond_mutex);
+                event_auth = (volatile struct amf_event_s *)e;
+                pthread_cond_signal(&auth_cond);
+                pthread_mutex_unlock(&auth_cond_mutex);
+                auth_count++;
+                /* Only block if the socket is actively waiting AND this is
+                 * the first AUSF response (POST). Otherwise dispatch
+                 * normally so the AMF event loop can never deadlock. */
+                if (auth_count == 1 && socket_waiting_for_auth) {
+                    printf("[amf-sm] waiting for socket to finish processing\n");
+                    fflush(stdout);
+                    /* 10s timeout: socket should signal once it's done
+                     * sending NAS Auth Request (typically <100ms). If we
+                     * time out, fall through to normal dispatch. */
+                    struct timespec ts;
+                    clock_gettime(CLOCK_REALTIME, &ts);
+                    ts.tv_sec += 10;
+                    pthread_mutex_lock(&send_auth_cond_mutex);
+                    int rv = pthread_cond_timedwait(&send_auth_cond,
+                            &send_auth_cond_mutex, &ts);
+                    pthread_mutex_unlock(&send_auth_cond_mutex);
+                    if (rv == 0) {
+                        auth_intercepted = 1;
+                        printf("[amf-sm] socket done, skipping FSM dispatch\n");
+                    } else {
+                        printf("[amf-sm] !!! socket signal timed out (rv=%d), "
+                               "dispatching normally\n", rv);
+                    }
+                    fflush(stdout);
+                } else if (auth_count == 1) {
+                    printf("[amf-sm] socket not waiting (already gave up), "
+                           "dispatching normally\n");
+                    fflush(stdout);
+                }
+            }
+
+            if (!auth_intercepted)
+                ogs_fsm_dispatch(&amf_ue->sm, e);
             break;
 
         CASE(OGS_SBI_SERVICE_NAME_NSMF_PDUSESSION)
