diff --git a/include/srsran/cu_cp/test_client_notify.h b/include/srsran/cu_cp/test_client_notify.h
new file mode 100644
--- /dev/null
+++ b/include/srsran/cu_cp/test_client_notify.h
@@ -0,0 +1,15 @@
+#pragma once
+
+#include <string>
+
+namespace srsran {
+namespace srs_cu_cp {
+
+/// Push an event symbol to the LogExecutor testing client over the
+/// gNB test socket (no-op if no client is connected). Called by the
+/// RRC layer when significant UE messages are received, so passive
+/// dispatcher commands (e.g. rrc_sm_cmd) get a meaningful response.
+void notify_test_client(const std::string& msg);
+
+} // namespace srs_cu_cp
+} // namespace srsran
diff --git a/lib/cu_cp/rrc_socket.cpp b/lib/cu_cp/rrc_socket.cpp
new file mode 100644
--- /dev/null
+++ b/lib/cu_cp/rrc_socket.cpp
@@ -0,0 +1,254 @@
+#include "rrc_socket.h"
+
+#include "srsran/cu_cp/test_client_notify.h"
+#include <arpa/inet.h>
+#include <cstring>
+#include <netinet/in.h>
+#include <sys/socket.h>
+#include <thread>
+#include <unistd.h>
+
+namespace srsran {
+namespace srs_cu_cp {
+
+std::atomic<rrc_server*> rrc_server::g_instance{nullptr};
+
+void rrc_server::set_instance(rrc_server* inst)
+{
+  g_instance.store(inst);
+}
+
+void rrc_server::notify(const std::string& msg)
+{
+  rrc_server* inst = g_instance.load();
+  if (inst != nullptr) {
+    inst->notify_response(msg);
+  }
+}
+
+/* Free function defined in test_client_notify.h. Allows non-cu_cp modules
+ * (e.g. lib/rrc/ue) to push event notifications without depending on the
+ * full rrc_server type. */
+void notify_test_client(const std::string& msg)
+{
+  rrc_server::notify(msg);
+}
+
+rrc_server::rrc_server(uint16_t port_, test_command_dispatcher dispatcher_) :
+  port(port_), dispatcher(std::move(dispatcher_)), logger(srslog::fetch_basic_logger("TESTSRV"))
+{
+}
+
+rrc_server::~rrc_server()
+{
+  if (g_instance.load() == this) {
+    g_instance.store(nullptr);
+  }
+  stop();
+}
+
+void rrc_server::start()
+{
+  if (running.exchange(true)) {
+    return;
+  }
+  worker = std::thread([this]() { run(); });
+}
+
+void rrc_server::stop()
+{
+  if (!running.exchange(false)) {
+    return;
+  }
+  if (listen_fd >= 0) {
+    ::shutdown(listen_fd, SHUT_RDWR);
+    ::close(listen_fd);
+    listen_fd = -1;
+  }
+  {
+    std::lock_guard<std::mutex> lk(conn_mutex);
+    if (conn_fd >= 0) {
+      ::close(conn_fd);
+      conn_fd = -1;
+    }
+  }
+  if (worker.joinable()) {
+    worker.join();
+  }
+}
+
+void rrc_server::run()
+{
+  logger.info("testing client server thread started");
+
+  listen_fd = ::socket(AF_INET, SOCK_STREAM, 0);
+  if (listen_fd < 0) {
+    logger.error("socket() failed: {}", strerror(errno));
+    return;
+  }
+
+  int opt = 1;
+  ::setsockopt(listen_fd, SOL_SOCKET, SO_REUSEADDR | SO_REUSEPORT, &opt, sizeof(opt));
+
+  sockaddr_in addr{};
+  addr.sin_family      = AF_INET;
+  addr.sin_addr.s_addr = htonl(INADDR_LOOPBACK);
+  addr.sin_port        = htons(port);
+
+  if (::bind(listen_fd, reinterpret_cast<sockaddr*>(&addr), sizeof(addr)) < 0) {
+    logger.error("bind({}) failed: {}", port, strerror(errno));
+    ::close(listen_fd);
+    listen_fd = -1;
+    return;
+  }
+  if (::listen(listen_fd, 1) < 0) {
+    logger.error("listen() failed: {}", strerror(errno));
+    ::close(listen_fd);
+    listen_fd = -1;
+    return;
+  }
+  printf("[rrc_socket] listening on 127.0.0.1:%u — waiting for testing client...\n", port);
+  fflush(stdout);
+  logger.info("listening on 127.0.0.1:{}", port);
+
+  while (running.load()) {
+    sockaddr_in peer{};
+    socklen_t   peer_len = sizeof(peer);
+    int         fd       = ::accept(listen_fd, reinterpret_cast<sockaddr*>(&peer), &peer_len);
+    if (fd < 0) {
+      if (running.load()) {
+        logger.warning("accept() failed: {}", strerror(errno));
+      }
+      continue;
+    }
+
+    {
+      std::lock_guard<std::mutex> lk(conn_mutex);
+      conn_fd = fd;
+    }
+    printf("[rrc_socket] testing client connected to gNB (fd=%d)\n", conn_fd);
+    fflush(stdout);
+    logger.info("testing client connected");
+
+    char buf[512];
+    while (running.load()) {
+      ssize_t n = ::read(conn_fd, buf, sizeof(buf) - 1);
+      if (n <= 0) {
+        printf("[rrc_socket] testing client disconnected\n");
+        fflush(stdout);
+        logger.info("testing client disconnected");
+        break;
+      }
+      buf[n] = '\0';
+
+      std::string token(buf);
+      while (!token.empty() &&
+             (token.back() == '\n' || token.back() == '\r' || token.back() == ' ')) {
+        token.pop_back();
+      }
+
+      logger.info("received query: '{}'", token);
+
+      if (token == "Hello") {
+        notify_response("ACK from gnb\n");
+        continue;
+      }
+
+      if (token == "RACH_Reset") {
+        rach_counter_reset();
+        notify_response("DONE\n");
+        continue;
+      }
+
+      // Wait for UE RRC connection before executing any protocol command.
+      while (!rrc_connected.load()) {
+        std::this_thread::yield();
+      }
+
+      if (rach_count.load() > 1) {
+        logger.warning("RACH count > 1, rejecting command '{}'", token);
+        notify_response("null_action\n");
+        continue;
+      }
+
+      test_command cmd = parse(token);
+      if (cmd == test_command::unknown) {
+        logger.warning("unknown command '{}'", token);
+        notify_response("null_action\n");
+        continue;
+      }
+
+      logger.info("dispatching '{}'", token);
+      bool handled = dispatcher && dispatcher(cmd);
+      if (!handled) {
+        notify_response("null_action\n");
+      }
+    }
+
+    {
+      std::lock_guard<std::mutex> lk(conn_mutex);
+      ::close(conn_fd);
+      conn_fd = -1;
+    }
+    rrc_connected.store(false);
+    rach_count.store(0);
+  }
+}
+
+bool rrc_server::notify_response(const std::string& msg)
+{
+  std::lock_guard<std::mutex> lk(conn_mutex);
+  if (conn_fd < 0) {
+    logger.warning("notify_response: no client connected");
+    return false;
+  }
+  ssize_t sent = ::send(conn_fd, msg.data(), msg.size(), 0);
+  if (sent < 0) {
+    logger.error("send() failed: {}", strerror(errno));
+    return false;
+  }
+  return true;
+}
+
+void rrc_server::notify_rrc_connection()
+{
+  rrc_connected.store(true);
+}
+
+void rrc_server::rach_counter_increment()
+{
+  rach_count.fetch_add(1);
+}
+
+void rrc_server::rach_counter_reset()
+{
+  rach_count.store(0);
+}
+
+test_command rrc_server::parse(const std::string& t)
+{
+  if (t == "rrc_sm_cmd")               return test_command::rrc_sm_cmd;
+  if (t == "rrc_sm_cmd_replay")        return test_command::rrc_sm_cmd_replay;
+  if (t == "rrc_sm_cmd_protected")     return test_command::rrc_sm_cmd_protected;
+  if (t == "rrc_sm_cmd_plain_text")    return test_command::rrc_sm_cmd_plain_text;
+  if (t == "rrc_sm_cmd_null_security") return test_command::rrc_sm_cmd_null_security;
+  if (t == "rrc_sm_cmd_ns")            return test_command::rrc_sm_cmd_ns;
+  if (t == "rrc_sm_cmd_ns_plain_text") return test_command::rrc_sm_cmd_ns_plain_text;
+  if (t == "ue_cap_enquiry_protected") return test_command::ue_cap_enquiry_protected;
+  if (t == "ue_cap_enquiry_plaintext") return test_command::ue_cap_enquiry_plaintext;
+  if (t == "ue_cap_enquiry_plain_text") return test_command::ue_cap_enquiry_plaintext; // alias used in symbols.gnb.conf
+  if (t == "rrc_reconf_protected")     return test_command::rrc_reconf_protected;
+  if (t == "rrc_reconf_replay")        return test_command::rrc_reconf_replay;
+  if (t == "rrc_reconf_plain_text")    return test_command::rrc_reconf_plain_text;
+  if (t == "rrc_countercheck_protected")  return test_command::rrc_countercheck_protected;
+  if (t == "rrc_countercheck_plain_text") return test_command::rrc_countercheck_plain_text;
+  if (t == "rrc_ueinfo_req_protected")    return test_command::rrc_ueinfo_req_protected;
+  if (t == "rrc_ueinfo_req_plain_text")   return test_command::rrc_ueinfo_req_plain_text;
+  if (t == "rrc_release")              return test_command::rrc_release;
+  if (t == "rrc_reest_protected")      return test_command::rrc_reest_protected;
+  if (t == "rrc_reest_plain_text")     return test_command::rrc_reest_plain_text;
+  return test_command::unknown;
+}
+
+} // namespace srs_cu_cp
+} // namespace srsran
diff --git a/lib/cu_cp/rrc_socket.h b/lib/cu_cp/rrc_socket.h
new file mode 100644
--- /dev/null
+++ b/lib/cu_cp/rrc_socket.h
@@ -0,0 +1,100 @@
+#pragma once
+
+#include "srsran/srslog/srslog.h"
+#include <atomic>
+#include <functional>
+#include <mutex>
+#include <string>
+#include <thread>
+
+namespace srsran {
+namespace srs_cu_cp {
+
+/// Commands the test server can dispatch to the RRC/CU-CP layer.
+enum class test_command {
+  // Security Mode Command family — all variants resolve to the same
+  // passive-sync handler in cu_cp_impl (the auto-flow's NGAP
+  // InitialContextSetupRequest drives the actual RRC SMC; the response
+  // symbol "rrc_sm_cmd_complete" is pushed by the rrc_ue hook).
+  rrc_sm_cmd,
+  rrc_sm_cmd_replay,
+  rrc_sm_cmd_protected,
+  rrc_sm_cmd_plain_text,
+  rrc_sm_cmd_null_security,
+  rrc_sm_cmd_ns,                  // alias used by symbols.gnb.conf
+  rrc_sm_cmd_ns_plain_text,       // alias used by symbols.gnb.conf
+  // UE Capability Enquiry family
+  ue_cap_enquiry_protected,
+  ue_cap_enquiry_plaintext,
+  // RRC Reconfiguration family
+  rrc_reconf_protected,
+  rrc_reconf_replay,
+  rrc_reconf_plain_text,
+  // Counter Check / UE Information Request — modern srsRAN doesn't
+  // expose an active trigger nor a UE response handler for these in
+  // the CU-CP. Treated as immediate null_action so LogExecutor doesn't
+  // block waiting forever.
+  rrc_countercheck_protected,
+  rrc_countercheck_plain_text,
+  rrc_ueinfo_req_protected,
+  rrc_ueinfo_req_plain_text,
+  // Other (currently stubs)
+  rrc_release,
+  rrc_reest_protected,
+  rrc_reest_plain_text,
+  unknown
+};
+
+/// Returns true if the dispatcher took ownership of the response
+/// (will call notify_response asynchronously). Returns false to
+/// let rrc_server send a default "null_action" response.
+using test_command_dispatcher = std::function<bool(test_command)>;
+
+/// TCP server that accepts a single testing-client connection and
+/// dispatches commands to the CU-CP layer.
+class rrc_server
+{
+public:
+  rrc_server(uint16_t port, test_command_dispatcher dispatcher_);
+  ~rrc_server();
+
+  void start();
+  void stop();
+
+  /// Send a response string back to the connected testing client.
+  bool notify_response(const std::string& msg);
+
+  /// Called by the RRC layer once a UE RRC connection is established.
+  void notify_rrc_connection();
+
+  void rach_counter_increment();
+  void rach_counter_reset();
+
+  /// Register this server as the global instance so RRC layer code can
+  /// asynchronously push event notifications (e.g. SMC complete) without
+  /// holding a direct reference. Pass nullptr to clear.
+  static void set_instance(rrc_server* inst);
+
+  /// Send a message to the registered global instance (no-op if unset).
+  static void notify(const std::string& msg);
+
